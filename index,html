const chatHistory = [];

function askTopic(question) {
  showPage('learn');
  document.getElementById('chatInput').value = question;
  sendChat();
}

async function sendChat() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';

  addChatMsg(msg, 'user');
  chatHistory.push({role:'user', content: msg});

  const btn = document.getElementById('chatSendBtn');
  btn.disabled = true; btn.textContent = '…';

  // Typing indicator
  const typingId = 'typing_' + Date.now();
  const chatWin = document.getElementById('chatWindow');
  chatWin.innerHTML += `
    <div class="chat-msg ai" id="${typingId}">
      <div class="chat-avatar">AI</div>
      <div class="chat-typing">
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      </div>
    </div>`;
  chatWin.scrollTop = chatWin.scrollHeight;

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: `You are an expert penetration tester and cybersecurity mentor inside PenLab, an educational pentesting platform for beginners. 

Your role:
- Explain security concepts clearly with real examples
- Walk through how attacks work step by step
- Explain both the attack AND the defense/remediation
- Use code examples and payloads where helpful
- Keep responses focused and practical
- Always emphasize ethical and legal use — only test systems you own or have permission to test
- Format with **bold** for key terms and \`code\` for technical values
- Be encouraging — this is for learners

Never help with: targeting specific real systems without permission, creating malware, doxing, or any illegal activity.`,
        messages: chatHistory
      })
    });

    const data = await res.json();
    document.getElementById(typingId)?.remove();

    const reply = data.content?.[0]?.text || 'Sorry, I could not get a response.';
    chatHistory.push({role:'assistant', content: reply});
    addChatMsg(reply, 'ai');

  } catch(e) {
    document.getElementById(typingId)?.remove();
    addChatMsg('Connection error. Make sure you\'re on a network that can reach the API.', 'ai');
  }

  btn.disabled = false; btn.textContent = '▶ Ask';
}

function addChatMsg(text, role) {
  const chatWin = document.getElementById('chatWindow');
  // Convert markdown-lite to html
  const html = text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/`(.*?)`/g, '<code>$1</code>')
    .replace(/\n/g, '<br>');
  chatWin.innerHTML += `
    <div class="chat-msg ${role}">
      <div class="chat-avatar">${role === 'user' ? 'YOU' : 'AI'}</div>
      <div class="chat-bubble">${html}</div>
    </div>`;
  chatWin.scrollTop = chatWin.scrollHeight;
}

