// ══════════════════════════════════════
// CLAUDE PROXY — fetches headers server-side, no CORS
// ══════════════════════════════════════
async function fetchHeadersViaProxy(url) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      system: `You are an HTTP header fetcher. When given a URL, use the web_search tool or your knowledge to fetch that URL and return ONLY a valid JSON object of its response headers in lowercase keys. No explanation. No markdown. Just the raw JSON object like: {"content-type":"text/html","server":"nginx","strict-transport-security":"max-age=31536000","x-frame-options":"DENY"} etc. Include every header present. If you cannot fetch it, return {"error":"unreachable"}.`,
      tools: [{ type: 'web_search_20250305', name: 'web_search' }],
      messages: [{ role: 'user', content: `Fetch this URL and return its HTTP response headers as a JSON object: ${url}` }]
    })
  });
  const data = await res.json();
  // Extract the text content block
  const text = data.content?.filter(b => b.type === 'text').map(b => b.text).join('') || '';
  // Strip any markdown fences
  const clean = text.replace(/```json|```/g, '').trim();
  try { return JSON.parse(clean); } catch { return {}; }
}

async function runScan() {
  const url = document.getElementById('scanTarget').value.trim();
  if (!url) { toast('Enter a target URL first.', 'err'); return; }
  if (!url.startsWith('http')) { toast('URL must start with http:// or https://', 'err'); return; }

  const btn = document.getElementById('scanBtn');
  btn.disabled = true; btn.textContent = '⬡ Scanning…';
  const log = document.getElementById('scanLog');
  log.innerHTML = '';
  document.getElementById('findingsContainer').innerHTML = '<div style="text-align:center;padding:32px;color:var(--text3);font-family:var(--mono);font-size:11px">// scanning...</div>';

  const addLog = (msg, cls='t-dim') => {
    log.innerHTML += `<span class="${cls}">${msg}</span><br>`;
    log.scrollTop = log.scrollHeight;
  };

  addLog(`$ initiating scan: ${url}`, 't-green');
  state.scans++;
  document.getElementById('statScans').textContent = state.scans;
  logActivity(`Scan started: ${url}`, 'green');

  let prog = 0;
  const progEl = document.getElementById('scanProgress');
  const progTmr = setInterval(() => {
    prog = Math.min(prog + Math.random() * 6, 85);
    progEl.style.width = prog + '%';
  }, 300);

  let headers = {};

  // Step 1: try direct fetch (works if target allows CORS)
  addLog('$ attempting direct header fetch...', 't-dim');
  try {
    const res = await fetch(url, { method: 'HEAD', mode: 'cors', cache: 'no-cache' });
    res.headers.forEach((v, k) => { headers[k.toLowerCase()] = v; });
    if (headers['server']) state._serverHeader = headers['server'];
    addLog(`$ direct fetch OK — HTTP ${res.status} ${res.statusText}`, 't-green');
    addLog(`$ ${Object.keys(headers).length} headers received directly`, 't-dim');
  } catch(e) {
    addLog(`$ direct fetch blocked by CORS — routing via Claude proxy...`, 't-yellow');
    try {
      addLog(`$ proxy fetching ${url}...`, 't-dim');
      const proxyHeaders = await fetchHeadersViaProxy(url);
      if (proxyHeaders.error) {
        addLog(`$ proxy could not reach target: ${proxyHeaders.error}`, 't-red');
        addLog(`$ running URL-only checks...`, 't-dim');
      } else {
        headers = proxyHeaders;
        if (headers['server']) state._serverHeader = headers['server'];
        addLog(`$ proxy fetch OK — ${Object.keys(headers).length} headers retrieved`, 't-green');
        Object.entries(headers).forEach(([k,v]) => {
          addLog(`$   ${k}: ${v.substring(0,80)}${v.length>80?'…':''}`, 't-dim');
        });
      }
    } catch(pe) {
      addLog(`$ proxy error: ${pe.message}`, 't-red');
      addLog(`$ running URL-only checks...`, 't-dim');
    }
  }

  await delay(200);
  addLog('$ running security header checks...', 't-dim');
  await delay(300);

  const found = [];
  for (const check of CHECKS) {
    await delay(60);
    const failed = check.check(url, headers);
    if (failed) {
      found.push(check);
      const color = {critical:'t-red',high:'t-red',medium:'t-yellow',low:'t-blue',info:'t-dim'}[check.severity];
      addLog(`$ [${check.severity.toUpperCase()}] ${check.name}`, color);
    } else {
      addLog(`$ [OK] ${check.name}`, 't-green');
    }
  }

  found.forEach(f => {
    if (!state.findings.find(x => x.id === f.id)) state.findings.push({...f, url});
  });

  clearInterval(progTmr);
  progEl.style.width = '100%';
  setTimeout(() => { progEl.style.width = '0%'; }, 1500);

  addLog(`$ scan complete — ${found.length} issue${found.length!==1?'s':''} found`, found.length > 0 ? 't-yellow' : 't-green');
  updateFindingStat();
  renderFindings(found, url);
  document.getElementById('findingCount').textContent = `${found.length} issue${found.length!==1?'s':''}`;
  logActivity(`Scan complete: ${found.length} findings`, found.length > 0 ? 'yellow' : 'green');

  btn.disabled = false; btn.textContent = '⬡ Start Scan';
}

function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

function renderFindings(findings, url) {
  const container = document.getElementById('findingsContainer');
  if (!findings.length) {
    container.innerHTML = '<div style="text-align:center;padding:32px;color:var(--green);font-family:var(--mono);font-size:12px">✓ No issues detected</div>';
    return;
  }
  const sorted = [...findings].sort((a,b) => SEV_ORDER.indexOf(a.severity) - SEV_ORDER.indexOf(b.severity));
  container.innerHTML = sorted.map(f => `
    <div class="finding" id="f_${f.id}">
      <div class="finding-header" onclick="toggleFinding('${f.id}')">
        <span class="badge badge-${f.severity}">${f.severity}</span>
        <span class="finding-title">${f.name}</span>
        <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();addToReport('${f.id}','${f.name}','${f.severity}')">+ Report</button>
      </div>
      <div class="finding-body">
        <div class="finding-desc">${f.desc}</div>
        <div class="finding-detail">
          <strong>CVSS Score</strong>${f.cvss} / 10
          <strong>Remediation</strong>${f.remediation}
          <strong>Target</strong>${url}
        </div>
      </div>
    </div>
  `).join('');
}

function toggleFinding(id) {
  document.getElementById('f_'+id).classList.toggle('open');
}

