<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PenLab — Penetration Testing Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #080c10;
  --bg2: #0d1117;
  --bg3: #111820;
  --panel: #0e1520;
  --border: #1a2535;
  --border2: #1f2e42;
  --green: #00ff88;
  --green2: #00cc6a;
  --green-dim: rgba(0,255,136,0.08);
  --green-glow: rgba(0,255,136,0.15);
  --red: #ff4455;
  --red-dim: rgba(255,68,85,0.1);
  --yellow: #ffd000;
  --yellow-dim: rgba(255,208,0,0.08);
  --blue: #00aaff;
  --blue-dim: rgba(0,170,255,0.08);
  --text: #c8d8e8;
  --text2: #7a9ab8;
  --text3: #3a5068;
  --mono: 'Share Tech Mono', monospace;
  --head: 'Rajdhani', sans-serif;
  --body: 'Inter', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Grid background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* ── TOPBAR ── */
.topbar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(8,12,16,0.95);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px; height: 56px;
}
.topbar-brand {
  display: flex; align-items: center; gap: 12px;
}
.brand-icon {
  width: 32px; height: 32px;
  border: 1px solid var(--green);
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  box-shadow: 0 0 10px var(--green-glow);
  position: relative;
}
.brand-icon::before {
  content: '';
  position: absolute; inset: 3px;
  border: 1px solid rgba(0,255,136,0.2);
}
.brand-name {
  font-family: var(--head);
  font-size: 20px; font-weight: 700;
  letter-spacing: 3px;
  color: var(--green);
  text-shadow: 0 0 20px var(--green-glow);
}
.brand-version {
  font-family: var(--mono);
  font-size: 10px; color: var(--text3);
  letter-spacing: 1px;
}
.topbar-status {
  display: flex; align-items: center; gap: 20px;
  font-family: var(--mono); font-size: 11px; color: var(--text3);
}
.status-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 8px var(--green);
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }

/* ── NAV ── */
.nav {
  position: fixed; top: 56px; left: 0; bottom: 0; width: 220px; z-index: 90;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  padding: 24px 0;
  display: flex; flex-direction: column; gap: 4px;
}
.nav-section {
  font-family: var(--mono); font-size: 9px; letter-spacing: 2px;
  color: var(--text3); padding: 16px 20px 6px;
  text-transform: uppercase;
}
.nav-item {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 20px; cursor: pointer;
  font-family: var(--head); font-size: 14px; font-weight: 500;
  color: var(--text2); letter-spacing: 1px;
  border-left: 2px solid transparent;
  transition: all 0.15s;
  position: relative;
}
.nav-item:hover { color: var(--text); background: rgba(255,255,255,0.02); }
.nav-item.active {
  color: var(--green);
  border-left-color: var(--green);
  background: var(--green-dim);
}
.nav-item.active::after {
  content: '';
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 1px; background: var(--green);
  box-shadow: 0 0 8px var(--green);
}
.nav-icon { font-size: 16px; width: 20px; text-align: center; }
.nav-badge {
  margin-left: auto; font-family: var(--mono); font-size: 9px;
  padding: 2px 6px; background: var(--green-dim);
  border: 1px solid rgba(0,255,136,0.2); color: var(--green);
}

/* ── MAIN ── */
.main {
  margin-left: 220px;
  padding-top: 56px;
  min-height: 100vh;
  position: relative; z-index: 1;
}
.page { display: none; padding: 32px; }
.page.active { display: block; }

/* ── PAGE HEADER ── */
.page-header { margin-bottom: 28px; }
.page-eyebrow {
  font-family: var(--mono); font-size: 10px; letter-spacing: 3px;
  color: var(--green); text-transform: uppercase; margin-bottom: 6px;
}
.page-title {
  font-family: var(--head); font-size: 32px; font-weight: 700;
  color: white; letter-spacing: 2px; line-height: 1;
}
.page-sub { font-size: 13px; color: var(--text2); margin-top: 6px; line-height: 1.5; }

/* ── PANELS ── */
.panel {
  background: var(--panel);
  border: 1px solid var(--border);
  margin-bottom: 16px;
}
.panel-header {
  padding: 14px 20px;
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px;
}
.panel-title {
  font-family: var(--head); font-size: 13px; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase; color: var(--text);
  display: flex; align-items: center; gap: 8px;
}
.panel-body { padding: 20px; }

/* ── GRID ── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* ── INPUTS ── */
.input-group { margin-bottom: 16px; }
.input-label {
  font-family: var(--mono); font-size: 10px; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--text2); margin-bottom: 6px;
  display: flex; justify-content: space-between;
}
.input-field {
  width: 100%; background: var(--bg3);
  border: 1px solid var(--border2); color: var(--text);
  font-family: var(--mono); font-size: 13px;
  padding: 10px 14px; outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.input-field:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 2px var(--green-dim);
}
.input-field::placeholder { color: var(--text3); }
select.input-field { cursor: pointer; }
select.input-field option { background: var(--bg2); }

/* ── BUTTONS ── */
.btn {
  padding: 10px 20px; border: none; cursor: pointer;
  font-family: var(--head); font-size: 13px; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase;
  transition: all .15s; display: inline-flex; align-items: center; gap: 8px;
}
.btn-primary {
  background: var(--green); color: var(--bg);
  box-shadow: 0 0 20px var(--green-glow);
}
.btn-primary:hover {
  background: #00ffaa;
  box-shadow: 0 0 30px rgba(0,255,136,0.3);
}
.btn-primary:disabled { background: var(--border2); color: var(--text3); box-shadow: none; cursor: not-allowed; }
.btn-ghost {
  background: transparent; color: var(--text2);
  border: 1px solid var(--border2);
}
.btn-ghost:hover { border-color: var(--green); color: var(--green); }
.btn-danger {
  background: transparent; color: var(--red);
  border: 1px solid rgba(255,68,85,0.3);
}
.btn-danger:hover { background: var(--red-dim); }
.btn-sm { padding: 6px 12px; font-size: 11px; }
.btn-full { width: 100%; justify-content: center; }

/* ── TERMINAL ── */
.terminal {
  background: #040810;
  border: 1px solid var(--border);
  padding: 16px;
  font-family: var(--mono); font-size: 12px;
  min-height: 120px; max-height: 320px;
  overflow-y: auto; line-height: 1.8;
}
.terminal::-webkit-scrollbar { width: 4px; }
.terminal::-webkit-scrollbar-track { background: transparent; }
.terminal::-webkit-scrollbar-thumb { background: var(--border2); }
.t-green { color: var(--green); }
.t-red { color: var(--red); }
.t-yellow { color: var(--yellow); }
.t-blue { color: var(--blue); }
.t-dim { color: var(--text3); }
.t-white { color: white; }

/* ── BADGES ── */
.badge {
  font-family: var(--mono); font-size: 10px; letter-spacing: 1px;
  padding: 2px 8px; text-transform: uppercase;
}
.badge-critical { background: rgba(255,68,85,0.15); border: 1px solid rgba(255,68,85,0.4); color: var(--red); }
.badge-high { background: rgba(255,120,0,0.12); border: 1px solid rgba(255,120,0,0.3); color: #ff7800; }
.badge-medium { background: var(--yellow-dim); border: 1px solid rgba(255,208,0,0.3); color: var(--yellow); }
.badge-low { background: var(--blue-dim); border: 1px solid rgba(0,170,255,0.3); color: var(--blue); }
.badge-info { background: rgba(100,100,100,0.1); border: 1px solid var(--border2); color: var(--text2); }
.badge-ok { background: var(--green-dim); border: 1px solid rgba(0,255,136,0.3); color: var(--green); }

/* ── FINDING CARD ── */
.finding {
  border: 1px solid var(--border);
  margin-bottom: 10px;
  transition: border-color .15s;
}
.finding:hover { border-color: var(--border2); }
.finding-header {
  padding: 12px 16px;
  display: flex; align-items: center; gap: 12px; cursor: pointer;
  background: rgba(255,255,255,0.01);
}
.finding-title { font-family: var(--head); font-size: 13px; font-weight: 600; flex: 1; }
.finding-body { padding: 16px; border-top: 1px solid var(--border); display: none; }
.finding.open .finding-body { display: block; }
.finding-desc { font-size: 12px; color: var(--text2); line-height: 1.7; margin-bottom: 12px; }
.finding-detail { font-size: 11px; line-height: 1.6; }
.finding-detail strong { color: var(--text); display: block; font-family: var(--mono); font-size: 10px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; margin-top: 10px; color: var(--text2); }
.finding-detail code { background: var(--bg3); padding: 2px 6px; font-family: var(--mono); font-size: 11px; color: var(--yellow); }

/* ── PAYLOAD CARD ── */
.payload-card {
  background: var(--bg3); border: 1px solid var(--border);
  margin-bottom: 8px; transition: border-color .15s;
}
.payload-card:hover { border-color: var(--green); }
.payload-header {
  padding: 10px 14px; display: flex; align-items: center; gap: 10px;
  cursor: pointer;
}
.payload-title { font-family: var(--head); font-size: 12px; font-weight: 600; letter-spacing: 1px; flex: 1; }
.payload-body { padding: 0 14px 14px; display: none; }
.payload-card.open .payload-body { display: block; }
.payload-code {
  background: #040810; border: 1px solid var(--border);
  padding: 12px; font-family: var(--mono); font-size: 11px;
  color: var(--green); line-height: 1.6; word-break: break-all;
  position: relative; margin: 8px 0;
}
.payload-copy {
  position: absolute; top: 6px; right: 6px;
  background: var(--border2); border: none; color: var(--text2);
  font-family: var(--mono); font-size: 9px; padding: 3px 8px;
  cursor: pointer; letter-spacing: 1px;
}
.payload-copy:hover { color: var(--green); }
.payload-explain { font-size: 11px; color: var(--text2); line-height: 1.7; }
.payload-warn {
  font-size: 10px; color: var(--yellow); margin-top: 8px;
  padding: 6px 10px; background: var(--yellow-dim);
  border-left: 2px solid var(--yellow);
  font-family: var(--mono);
}

/* ── LEARN CHAT ── */
.chat-window {
  background: #040810; border: 1px solid var(--border);
  height: 420px; overflow-y: auto; padding: 20px;
  display: flex; flex-direction: column; gap: 14px;
}
.chat-window::-webkit-scrollbar { width: 4px; }
.chat-window::-webkit-scrollbar-thumb { background: var(--border2); }
.chat-msg { display: flex; gap: 10px; max-width: 88%; }
.chat-msg.user { align-self: flex-end; flex-direction: row-reverse; }
.chat-avatar {
  width: 28px; height: 28px; flex-shrink: 0;
  border: 1px solid var(--border2);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-family: var(--mono);
  align-self: flex-start;
}
.chat-msg.user .chat-avatar { background: var(--green-dim); border-color: rgba(0,255,136,0.3); color: var(--green); }
.chat-msg.ai .chat-avatar { background: var(--blue-dim); border-color: rgba(0,170,255,0.2); color: var(--blue); }
.chat-bubble {
  padding: 12px 14px; font-size: 12px; line-height: 1.75;
  border: 1px solid var(--border);
}
.chat-msg.user .chat-bubble { background: var(--green-dim); border-color: rgba(0,255,136,0.15); color: var(--text); }
.chat-msg.ai .chat-bubble { background: var(--panel); color: var(--text2); }
.chat-bubble code { font-family: var(--mono); background: var(--bg3); padding: 1px 5px; color: var(--yellow); font-size: 11px; }
.chat-bubble strong { color: var(--text); }
.chat-input-row { display: flex; gap: 8px; margin-top: 12px; }
.chat-typing {
  display: flex; align-items: center; gap: 6px;
  padding: 12px 14px; border: 1px solid var(--border);
  background: var(--panel); align-self: flex-start;
}
.typing-dot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--blue);
  animation: typing 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing { 0%,60%,100%{transform:translateY(0);opacity:.4;} 30%{transform:translateY(-4px);opacity:1;} }

/* ── REPORT ── */
.report-section { margin-bottom: 20px; }
.report-section-title {
  font-family: var(--head); font-size: 12px; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--text2); margin-bottom: 10px;
  padding-bottom: 6px; border-bottom: 1px solid var(--border);
}
.finding-item {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 14px; border: 1px solid var(--border);
  margin-bottom: 6px; background: var(--bg3);
}
.finding-item-title { flex: 1; font-size: 12px; }
.finding-item-actions { display: flex; gap: 6px; }

/* ── STAT CARDS ── */
.stat-card {
  background: var(--panel); border: 1px solid var(--border);
  padding: 20px; text-align: center;
}
.stat-num {
  font-family: var(--head); font-size: 36px; font-weight: 700;
  line-height: 1;
}
.stat-num.green { color: var(--green); text-shadow: 0 0 20px var(--green-glow); }
.stat-num.red { color: var(--red); }
.stat-num.yellow { color: var(--yellow); }
.stat-num.blue { color: var(--blue); }
.stat-label {
  font-family: var(--mono); font-size: 10px; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--text3); margin-top: 6px;
}

/* ── LEARN TOPICS ── */
.topic-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 16px; }
.topic-btn {
  padding: 12px; background: var(--bg3); border: 1px solid var(--border);
  cursor: pointer; text-align: left; transition: all .15s;
  font-family: var(--head); color: var(--text2);
}
.topic-btn:hover { border-color: var(--green); color: var(--green); background: var(--green-dim); }
.topic-icon { font-size: 18px; margin-bottom: 4px; }
.topic-name { font-size: 12px; font-weight: 600; letter-spacing: 1px; }
.topic-desc { font-size: 10px; color: var(--text3); margin-top: 2px; font-family: var(--body); }

/* ── PROGRESS BAR ── */
.progress-bar { height: 3px; background: var(--border); overflow: hidden; }
.progress-fill { height: 100%; background: var(--green); transition: width .3s; box-shadow: 0 0 6px var(--green); }

/* ── SCAN PROGRESS ── */
.scan-step {
  display: flex; align-items: center; gap: 12px;
  padding: 8px 0; border-bottom: 1px solid var(--border);
  font-family: var(--mono); font-size: 11px;
}
.scan-step:last-child { border-bottom: none; }
.step-icon { width: 20px; text-align: center; }
.step-text { flex: 1; color: var(--text2); }
.step-status { font-size: 10px; }

/* ── DIVIDER ── */
.divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: 24px; right: 24px;
  background: var(--panel); border: 1px solid var(--border);
  padding: 12px 18px; font-family: var(--mono); font-size: 11px;
  z-index: 999; transform: translateY(80px); opacity: 0;
  transition: all .25s; border-left: 3px solid var(--green);
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.err { border-left-color: var(--red); }

/* ── MOBILE ── */
@media(max-width:768px) {
  .nav { display: none; }
  .main { margin-left: 0; }
  .grid-2,.grid-3 { grid-template-columns: 1fr; }
  .topic-grid { grid-template-columns: 1fr 1fr; }
  .page { padding: 16px; }
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar-brand">
    <div class="brand-icon">⬡</div>
    <div>
      <div class="brand-name">PENLAB</div>
    </div>
    <div class="brand-version">v1.0 // EDUCATIONAL</div>
  </div>
  <div class="topbar-status">
    <div class="status-dot"></div>
    <span>SYSTEM ONLINE</span>
    <span style="color:var(--border2)">|</span>
    <span id="clockDisplay"></span>
  </div>
</div>

<!-- NAV -->
<nav class="nav">
  <div class="nav-section">Modules</div>
  <div class="nav-item active" id="nav-dashboard" onclick="showPage('dashboard')">
    <span class="nav-icon">⊞</span> Dashboard
  </div>
  <div class="nav-item" id="nav-scanner" onclick="showPage('scanner')">
    <span class="nav-icon">⬡</span> Scanner
  </div>
  <div class="nav-item" id="nav-payloads" onclick="showPage('payloads')">
    <span class="nav-icon">◈</span> Payloads
  </div>
  <div class="nav-item" id="nav-learn" onclick="showPage('learn')">
    <span class="nav-icon">◎</span> Learn
    <span class="nav-badge">AI</span>
  </div>
  <div class="nav-item" id="nav-report" onclick="showPage('report')">
    <span class="nav-icon">▤</span> Report
  </div>
  <div class="nav-section" style="margin-top:auto">Info</div>
  <div class="nav-item" style="font-size:11px;color:var(--text3);cursor:default;border-left:none">
    <span class="nav-icon">⚠</span> For authorized testing only
  </div>
</nav>

<!-- MAIN -->
<main class="main">

<!-- ═══ DASHBOARD ═══ -->
<div class="page active" id="page-dashboard">
  <div class="page-header">
    <div class="page-eyebrow">// overview</div>
    <div class="page-title">DASHBOARD</div>
    <div class="page-sub">Entry-level penetration testing toolkit — web & network analysis, payload generation, AI-guided learning.</div>
  </div>

  <div class="grid-3" style="margin-bottom:16px">
    <div class="stat-card">
      <div class="stat-num red" id="statFindings">0</div>
      <div class="stat-label">Findings</div>
    </div>
    <div class="stat-card">
      <div class="stat-num yellow" id="statScans">0</div>
      <div class="stat-label">Scans Run</div>
    </div>
    <div class="stat-card">
      <div class="stat-num green" id="statPayloads">0</div>
      <div class="stat-label">Payloads Generated</div>
    </div>
  </div>

  <div class="grid-2">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">⬡ Quick Scan</div>
      </div>
      <div class="panel-body">
        <div class="input-group">
          <div class="input-label">Target URL</div>
          <input class="input-field" id="dashTarget" placeholder="https://example.com" type="url">
        </div>
        <button class="btn btn-primary btn-full" onclick="showPage('scanner');document.getElementById('scanTarget').value=document.getElementById('dashTarget').value">
          ⬡ Launch Scanner
        </button>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <div class="panel-title">◎ Recent Activity</div>
      </div>
      <div class="panel-body">
        <div class="terminal" id="activityLog" style="min-height:80px">
          <span class="t-green">$</span> <span class="t-dim">penlab initialized</span><br>
          <span class="t-green">$</span> <span class="t-dim">all modules loaded</span><br>
          <span class="t-green">$</span> <span class="t-dim">awaiting target...</span>
        </div>
      </div>
    </div>
  </div>

  <div class="grid-3" style="margin-top:16px">
    <div class="panel" style="cursor:pointer" onclick="showPage('scanner')">
      <div class="panel-body" style="text-align:center;padding:24px">
        <div style="font-size:32px;margin-bottom:10px">⬡</div>
        <div style="font-family:var(--head);font-size:15px;font-weight:700;letter-spacing:2px;color:var(--green);margin-bottom:6px">SCANNER</div>
        <div style="font-size:11px;color:var(--text2);line-height:1.6">Analyze headers, cookies, HTTPS config, common misconfigurations</div>
      </div>
    </div>
