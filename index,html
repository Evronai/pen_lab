function addToReport(id, name, severity) {
  if (!state.reportFindings.find(f => f.name === name)) {
    state.reportFindings.push({id, name, severity, notes:''});
    updateRiskCounts();
    toast(`"${name}" added to report.`);
  } else {
    toast('Already in report.', 'err');
  }
}

function addManualFinding() {
  const name = prompt('Finding name:');
  if (!name) return;
  const sev = prompt('Severity (critical/high/medium/low/info):') || 'medium';
  addToReport(null, name, sev);
  renderReportFindings();
}

function renderReportFindings() {
  const container = document.getElementById('reportFindings');
  if (!state.reportFindings.length) {
    container.innerHTML = '<div style="text-align:center;padding:24px;color:var(--text3);font-family:var(--mono);font-size:11px">// no findings yet</div>';
    return;
  }
  container.innerHTML = state.reportFindings.map((f, i) => `
    <div class="finding-item">
      <span class="badge badge-${f.severity}">${f.severity}</span>
      <span class="finding-item-title">${f.name}</span>
      <div class="finding-item-actions">
        <button class="btn btn-danger btn-sm" onclick="removeFinding(${i})">✕</button>
      </div>
    </div>
  `).join('');
  updateRiskCounts();
}

function removeFinding(i) {
  state.reportFindings.splice(i, 1);
  renderReportFindings();
}

function updateRiskCounts() {
  ['critical','high','medium'].forEach(s => {
    document.getElementById('rpt'+s.charAt(0).toUpperCase()+s.slice(1)).textContent =
      state.reportFindings.filter(f => f.severity === s).length;
  });
}

function generateReport() {
  const tester = document.getElementById('rptTester').value || 'Unknown';
  const target = document.getElementById('rptTarget').value || 'Unknown';
  const scope = document.getElementById('rptScope').value || 'Unknown';
  const date = document.getElementById('rptDate').value || new Date().toISOString().split('T')[0];
  const summary = document.getElementById('rptSummary').value || 'No summary provided.';

  const severityCounts = {};
  SEV_ORDER.forEach(s => severityCounts[s] = state.reportFindings.filter(f => f.severity===s).length);

  const divider = '═'.repeat(64);
  const line = '─'.repeat(64);

  let report = `
${divider}
  PENETRATION TEST REPORT
  Generated by PenLab v1.0
${divider}

ENGAGEMENT DETAILS
${line}
Tester        : ${tester}
Target        : ${target}
Scope         : ${scope}
Date          : ${date}
Tool          : PenLab v1.0 (Educational)

EXECUTIVE SUMMARY
${line}
${summary}

RISK SUMMARY
${line}
Critical  : ${severityCounts.critical}
High      : ${severityCounts.high}
Medium    : ${severityCounts.medium}
Low       : ${severityCounts.low}
Info      : ${severityCounts.info}
Total     : ${state.reportFindings.length}

FINDINGS
${line}
`;

  if (!state.reportFindings.length) {
    report += 'No findings recorded.\n';
  } else {
    state.reportFindings.forEach((f, i) => {
      const fdata = CHECKS.find(c => c.id === f.id) || {};
      report += `
[${i+1}] ${f.name}
Severity    : ${f.severity.toUpperCase()}
${fdata.cvss ? `CVSS Score  : ${fdata.cvss} / 10\n` : ''}${fdata.desc ? `Description : ${fdata.desc}\n` : ''}${fdata.remediation ? `Remediation : ${fdata.remediation}\n` : ''}${line}
`;
    });
  }

  report += `
DISCLAIMER
${line}
This report was generated using PenLab for educational purposes.
All testing was performed on authorized systems only.
This report does not constitute professional security advice.
`;

  document.getElementById('reportText').textContent = report;
  document.getElementById('reportOutput').style.display = 'block';
  document.getElementById('reportOutput').scrollIntoView({behavior:'smooth'});
  toast('Report generated!');
}

function downloadReport() {
  const text = document.getElementById('reportText').textContent;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([text], {type:'text/plain'}));
  a.download = `penlab-report-${Date.now()}.txt`;
  a.click();
  toast('Report downloaded.');
}

